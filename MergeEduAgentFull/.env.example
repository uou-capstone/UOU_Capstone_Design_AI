PORT=4000
WEB_PORT=5173
AI_BRIDGE_PORT=8001
MODEL_NAME=gemini-3-flash-preview
GOOGLE_API_KEY=YOUR_KEY_HERE
PASS_SCORE_RATIO=0.7
CONTEXT_MAX_CHARS=12000
RECENT_MESSAGES_N=12
DATA_DIR=./apps/server/data
UPLOAD_DIR=./apps/server/uploads
AI_BRIDGE_URL=http://127.0.0.1:8001
MAX_UPLOAD_MB=25
ORCHESTRATOR_THINK_TIMEOUT_MS=1200
GEMINI_CACHE_TTL_SECONDS=86400
APP_ORIGIN=http://localhost:5173
AUTH_COOKIE_NAME=merge_edu_session
AUTH_SESSION_TTL_DAYS=14
AUTH_EMAIL_DELIVERY_MODE=dev
AUTH_DEV_EXPOSE_VERIFICATION_CODE=true
AUTH_VERIFICATION_CODE_SECRET=
AUTH_ALLOW_LEGACY_VERIFICATION_HASH=false
AUTH_EMAIL_RESEND_COOLDOWN_SECONDS=60
REQUEST_ENCRYPTION_MODE=required
REQUEST_ENCRYPTION_REQUIRED_PATHS=/api/auth/signup,/api/auth/register,/api/auth/login,/api/auth/verify-email,/api/auth/resend-verification
# 실제 이메일 인증을 쓰려면 AUTH_EMAIL_DELIVERY_MODE=smtp로 바꾸고,
# AUTH_VERIFICATION_CODE_SECRET 및 SMTP_* 값을 모두 채워야 합니다.
# SMTP_HOST=smtp.naver.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# AUTH_BOOTSTRAP_SECRET=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
